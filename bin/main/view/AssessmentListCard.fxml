<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <VBox alignment="CENTER_LEFT" minHeight="90" spacing="6">
        <padding>
            <Insets top="8" right="8" bottom="8" left="15" />
        </padding>

        <Label fx:id="assessmentName" styleClass="grade-title-label" />

        <HBox spacing="6">
            <Label fx:id="courseCode" styleClass="tag-label" />
        </HBox>

        <Label fx:id="maxScore" styleClass="cell_small_label" />
    </VBox>
</HBox>
