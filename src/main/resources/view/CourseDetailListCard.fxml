<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <VBox alignment="CENTER_LEFT" minHeight="150" spacing="8">
        <padding>
            <Insets top="10" right="12" bottom="10" left="15" />
        </padding>

        <HBox spacing="4">
            <Label fx:id="id" styleClass="cell_big_label">
                <minWidth>
                    <Region fx:constant="USE_PREF_SIZE" />
                </minWidth>
            </Label>
            <Label fx:id="courseCode" styleClass="cell_big_label" />
        </HBox>

        <Label fx:id="summary" styleClass="cell_small_label" />

        <VBox spacing="4">
            <Label text="Assessments" styleClass="section-bubble-label" />
            <VBox fx:id="assessmentsContainer" spacing="3" />
        </VBox>

        <VBox spacing="4">
            <Label text="Students" styleClass="section-bubble-label" />
            <VBox fx:id="studentsContainer" spacing="3" />
        </VBox>
    </VBox>
</HBox>
