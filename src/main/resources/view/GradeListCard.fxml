<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <VBox alignment="CENTER_LEFT" spacing="6">
        <padding>
            <Insets top="10" right="12" bottom="10" left="15" />
        </padding>

        <Label fx:id="assessmentName" styleClass="grade-title-label" />

        <HBox spacing="6">
            <Label fx:id="courseCode" styleClass="tag-label" />
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="studentEntry" styleClass="grade-row-text" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="score" styleClass="grade-score-text" />
        </HBox>
    </VBox>
</HBox>
