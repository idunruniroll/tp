@startuml
skin rose
skinparam ActivityFontSize 15
skinparam ArrowFontSize 12

'Since the beta syntax does not support placing the condition outside the
'diamond we place it as the true branch instead.

start
:parse command arguments;

if () then ([missing required parameters?])
    :return format error message;
    stop
else ([else])
endif

if () then ([invalid course code?])
    :return "Invalid course code";
    stop
else ([else])
endif

if () then ([course code not found?])
    :return "Course <code> not found";
    stop
else ([else])
endif

if () then ([invalid student ID?])
    :return "Invalid student ID";
    stop
else ([else])
endif

if () then ([invalid name?])
    :return "Invalid name";
    stop
else ([else])
endif

if () then ([email provided?])
    if () then ([invalid email?])
        :return "Invalid email address";
        stop
    else ([else])
    endif
else ([else])
endif

if () then ([duplicate student ID in course?])
    :return "Student <id> already exists\nin <course>";
    stop
else ([else])
endif

:add student to course roster;
:save changes in storage;

if () then ([save failed?])
    :return "Unable to save changes";
    stop
else ([else])
endif

:update student list view;
stop
@enduml
