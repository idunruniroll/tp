@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":AddGradeCommandParser" as AddGradeCommandParser LOGIC_COLOR
participant "cmd:AddGradeCommand" as AddGradeCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("addgrade c/CS2103T id/A0123456B as/Assignment1 g/95")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("addgrade c/CS2103T id/A0123456B as/Assignment1 g/95")
activate AddressBookParser

create AddGradeCommandParser
AddressBookParser -> AddGradeCommandParser
activate AddGradeCommandParser

AddGradeCommandParser --> AddressBookParser
deactivate AddGradeCommandParser

AddressBookParser -> AddGradeCommandParser : parse("c/CS2103T id/A0123456B as/Assignment1 g/95")
activate AddGradeCommandParser

create AddGradeCommand
AddGradeCommandParser -> AddGradeCommand
activate AddGradeCommand

AddGradeCommand --> AddGradeCommandParser :
deactivate AddGradeCommand

AddGradeCommandParser --> AddressBookParser : cmd
deactivate AddGradeCommandParser
'Hidden arrow to position the destroy marker below the end of the activation bar.
AddGradeCommandParser -[hidden]-> AddressBookParser
destroy AddGradeCommandParser

AddressBookParser --> LogicManager : cmd
deactivate AddressBookParser

LogicManager -> AddGradeCommand : execute(m)
activate AddGradeCommand

AddGradeCommand -> Model : addGrade(courseCode, studentId, assessmentName, score)
activate Model

Model --> AddGradeCommand
deactivate Model

create CommandResult
AddGradeCommand -> CommandResult
activate CommandResult

CommandResult --> AddGradeCommand
deactivate CommandResult

AddGradeCommand --> LogicManager : r
deactivate AddGradeCommand

[<--LogicManager
deactivate LogicManager
@enduml
