@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":RemoveXYZCommandParser" as RemoveXYZCommandParser LOGIC_COLOR
participant "removeXYZCommand:RemoveXYZCommand" as RemoveXYZCommand LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "model:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("removeXYZ c/CS2103...")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("removeXYZ c/CS2103...")
activate AddressBookParser

AddressBookParser -> RemoveXYZCommandParser : parse("CS2103...")
activate RemoveXYZCommandParser
RemoveXYZCommandParser --> AddressBookParser : removeXYZCommandParser
deactivate RemoveXYZCommandParser

AddressBookParser --> LogicManager : removeXYZCommandParser
deactivate AddressBookParser

LogicManager -> RemoveXYZCommandParser : execute(model)
activate RemoveXYZCommandParser

RemoveXYZCommandParser -> Model : getXYZList()
activate Model
Model --> RemoveXYZCommandParser : lastShownList
deactivate Model

alt index is valid
    RemoveXYZCommandParser -> Model : removeXYZ(objectToDelete)
    activate Model
    Model --> RemoveXYZCommand
    deactivate Model
    RemoveXYZCommand --> LogicManager : CommandResult
else index is invalid
    RemoveXYZCommand --> LogicManager : throws CommandException
end

deactivate RemoveXYZCommand
[<-- LogicManager
deactivate LogicManager
@enduml
